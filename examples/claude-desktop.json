{
  "mcpServers": {
    "github-health-monitor": {
      "command": "node",
      "args": ["/absolute/path/to/github-health-monitor/dist/index.js"],
      "env": {
        "GITHUB_TOKEN": "ghp_replace_with_your_token",
        "STALE_BRANCH_DAYS": "30",
        "OLD_PR_DAYS": "14",
        "UNRESPONSIVE_ISSUE_DAYS": "7"
      }
    }
  }
}
